# ═══════════════════════════════════════════════════════════════════════════
# Copie este ficheiro para `.env` e preencha os valores (`cp .env.example .env`).
# ═══════════════════════════════════════════════════════════════════════════

# ─── Docker Compose / Traefik (obrigatório em produção ao usar docker-compose.yml)
# Domínio base (apex), ex.: liloclub.app — usado nos labels Traefik e em URLs interpoladas.
DOMAIN=example.com

# ─── Postgres (Drizzle / API)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lilo_wms

# ─── Segredos JWT (API — docker-compose interpola JWT_*)
JWT_SECRET=change-me-in-production-min-32-chars-please-xxxxxxxx
JWT_EXPIRES_IN=1h
JWT_COOKIE_NAME=access_token
JWT_COOKIE_MAX_AGE_MS=3600000

# ─── OAuth Google (API)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── URLs públicas da aplicação (API — placeholders no compose para callback / cookies)
# Em dev local omita ou use localhost; em produção alinhe com HTTPS e DOMAIN.
WEB_APP_URL=https://example.com

# ─── Armazenamento Cloudflare R2 (API — opcional)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=

# ─── API NestJS — desenvolvimento local (apps/api/src/main.ts usa estes nomes)
# Para `docker compose`, o compose define PORT / CORS_* em linha — mantenha o .env
# com DOMAIN/JWT/etc. para substituição de variáveis.
API_HOST=0.0.0.0
API_PORT=4000
CORS_ORIGIN=http://localhost:3000

# ─── Swagger (API — configure conforme implantar)
SWAGGER_ENABLED=false

# ─── Next.js (apps/web)
# Browser: URL pública da API em JSON (compose usa https://${DOMAIN}/api em produção).
NEXT_PUBLIC_API_URL=http://localhost:4000
# Server Components / SSR: chamada à API dentro da rede Docker (compose usa api:4000).
API_INTERNAL_URL=http://localhost:4000/api

# ─── PWA Vite — adicione VITE_* aqui quando o frontend expuser variáveis de build.
# VITE_PUBLIC_API_URL=https://example.com/api

# ─── Worker / BullMQ (Redis)
REDIS_URL=redis://127.0.0.1:6379
# Dentro da stack Docker o compose pode usar: redis://redis:6379
WORKER_CONCURRENCY=5
